{
  "name": "@koryla/react",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "require": "./dist/server.cjs",
      "types": "./dist/server.d.ts"
    },
    "./components": {
      "import": "./dist/components.js",
      "require": "./dist/components.cjs",
      "types": "./dist/components.d.ts"
    }
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts src/components.tsx --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/server.ts src/components.tsx --format esm,cjs --dts --watch"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@koryla/core": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^19",
    "react": "^19",
    "tsup": "^8.0.0",
    "typescript": "^5"
  }
}
